# App
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=
AUTH_SECRET=ersetze-dies-durch-einen-langen-zufaelligen-wert
ADMIN_EMAILS=
EMBEDDED_COOKIE_MODE=false

# Datenbank: Neon/PostgreSQL fuer Vercel/Production.
# Die Neon-Verbindungszeichenfolge sollte sslmode=require enthalten.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_DEMO_MODE=true

# E-Mail fuer Passwort vergessen. Ohne RESEND_API_KEY wird der Reset-Link lokal nur in Development ausgegeben.
EMAIL_FROM="TV Europabad Marbach <noreply@deine-domain.de>"
RESEND_API_KEY=

# Verein
NEXT_PUBLIC_CLUB_NAME="TV Europabad Marbach"
